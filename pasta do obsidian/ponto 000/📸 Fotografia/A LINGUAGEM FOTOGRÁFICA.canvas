		{"id":"26bec573bf28274a","x":-885,"y":-860,"width":404,"height":348,"type":"text","text":"Invenção da Fotografia em 1839.\n\nFim da supremacia artística das classes dominantes ?\n\nA maquina começa a fazer a arte ou asssim se pensava...\n\n"},
		{"id":"8faceab6bc7332e8","x":-460,"y":-711,"width":524,"height":50,"type":"text","text":"surgimento da cidade da foto = Londres"},
